# Development environment config
NODE_ENV=development
APP_PORT=3000
DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/fintech_dev
JWT_SECRET=dev_jwt_secret
JWT_EXPIRES_IN=3600s
REFRESH_TOKEN_EXPIRES_IN=7d
SMTP_HOST=smtp.dev.example.com
SMTP_PORT=587
SMTP_USER=dev-user
SMTP_PASS=dev-password
NOTIFICATION_PROVIDER_API_KEY=dev_notification_api_key
ENABLE_AUDIT_LOGS=true
HEALTHCHECK_SECRET=dev_healthcheck_secret
CORS_ORIGINS=http://localhost:3000
ADMIN_EMAIL=admin@dev.example.com
