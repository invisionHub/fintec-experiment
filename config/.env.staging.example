# Staging environment config
NODE_ENV=staging
APP_PORT=4000
DATABASE_URL=postgresql://staging_user:staging_password@localhost:5432/fintech_staging
JWT_SECRET=staging_jwt_secret
JWT_EXPIRES_IN=3600s
REFRESH_TOKEN_EXPIRES_IN=7d
SMTP_HOST=smtp.staging.example.com
SMTP_PORT=587
SMTP_USER=staging-user
SMTP_PASS=staging-password
NOTIFICATION_PROVIDER_API_KEY=staging_notification_api_key
ENABLE_AUDIT_LOGS=true
HEALTHCHECK_SECRET=staging_healthcheck_secret
CORS_ORIGINS=https://staging.example.com
ADMIN_EMAIL=admin@staging.example.com
