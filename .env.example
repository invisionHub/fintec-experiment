# Core application
APP_PORT=3000
NODE_ENV=development
APP_NAME=fintech-api

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fintech_db

# Authentication
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=3600s
REFRESH_TOKEN_EXPIRES_IN=7d

# Email / notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=example-user
SMTP_PASS=example-password
NOTIFICATION_PROVIDER_API_KEY=your_notification_api_key

# Monitoring and auditing
ENABLE_AUDIT_LOGS=true
HEALTHCHECK_SECRET=your_healthcheck_secret

# CORS
CORS_ORIGINS=http://localhost:3000

# Optional admin settings
ADMIN_EMAIL=admin@example.com
